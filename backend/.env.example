# Server
PORT=8001
NODE_ENV=development

# Database — use "memory" for an in-memory MongoDB (local dev), or a real connection string
MONGO_URI=memory

# Auth
JWT_SECRET=change_me_to_a_long_random_string

# Google Gemini (skill-gap analysis). If unset, the app falls back to local logic.
GOOGLE_AI_KEY=

# Affinda resume parser (optional). If unset, falls back to local pdf-parse.
AFFINDA_API_KEY=
AFFINDA_API_URL=https://api.affinda.com/v3

# Python ML microservice (optional, used for fraud detection on job posts)
ML_SERVICE_URL=http://localhost:8002

# News feed (optional). If unset, live Hacker News stories are served instead.
NEWS_API_KEY=

# Live GST registry lookup provider (optional, e.g. a GSP API).
# If unset, GSTIN validation uses the official offline check-digit algorithm.
GST_VERIFY_URL=
GST_VERIFY_KEY=
